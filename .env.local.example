# Supabase — lấy tại: Project Settings > Data API & API Keys
# Copy file này thành .env.local rồi điền giá trị thật.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# (Tuỳ chọn) cho thao tác server-side cần quyền cao — KHÔNG để lộ ra client.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# (Tuỳ chọn — cho tính năng OCR hoá đơn sau này)
# ANTHROPIC_API_KEY=

# Lark API (đọc Bitable trực tiếp) — SERVER-ONLY, KHÔNG có NEXT_PUBLIC
# Lấy ở https://open.larksuite.com/app (Custom App)
# LARK_APP_ID=cli_xxxxxxxxxxxx
# LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
# LARK_BASE_TOKEN=LsipbJ26HaogeVs2hX0jjGQxpbb   # = app_token trong link /base/<đây>?from=...

# (Tuỳ chọn) Sentry — theo dõi lỗi production. Lấy DSN tại sentry.io > Project Settings > Client Keys (DSN)
# Không có DSN thì Sentry tự tắt (no-op). Đặt cả 2 (server + client) cùng 1 giá trị DSN.
# SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
