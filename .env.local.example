# Supabase — lấy tại: Project Settings > Data API & API Keys
# Copy file này thành .env.local rồi điền giá trị thật.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# (Tuỳ chọn) cho thao tác server-side cần quyền cao — KHÔNG để lộ ra client.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# (Tuỳ chọn — cho tính năng OCR hoá đơn sau này)
# ANTHROPIC_API_KEY=
