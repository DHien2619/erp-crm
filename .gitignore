# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# Dữ liệu tài chính thô — KHÔNG commit
*.xlsx
supabase/_data.json
supabase/_clean.xlsx

# Google service account key — KHÔNG commit (chứa private key)
*.iam.gserviceaccount.com.json
*-s1-*.json
*service-account*.json
gcp-*.json

# Google OAuth — KHÔNG commit
oauth_client.json
client_secret*.json
supabase/_oauth_token.txt

# n8n workflow JSON — chứa SYNC_SECRET + webhook URL, giữ local
n8n/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
